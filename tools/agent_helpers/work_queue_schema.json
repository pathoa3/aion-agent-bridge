{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["phase", "stages"],
  "properties": {
    "phase": {"type": "string"},
    "updated": {"type": "string"},
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "script", "status", "attempts", "fallback", "fallback_status", "last_error", "produced_artifacts"],
        "properties": {
          "name": {"type": "string"},
          "script": {"type": "string"},
          "status": {"enum": ["pending", "running", "completed", "blocked"]},
          "attempts": {"type": "integer", "minimum": 0},
          "primary_result": {"type": "string"},
          "fallback": {"type": "string"},
          "fallback_status": {"enum": ["not_needed", "pending", "running", "completed", "blocked"]},
          "last_error": {"type": "string"},
          "produced_artifacts": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
